{
  "schemaVersion": 1,
  "id": "donut-notifier",
  "version": "0.1.0",
  "name": "Donut Notifier",
  "description": "A high-performance spawner detection addon for Meteor Client.",
  "authors": [
    "Jamie"
  ],
  "contact": {
